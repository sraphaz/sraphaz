---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import { ui, type Locale } from '../../i18n/strings';

const locale = (Astro.url.searchParams.get('lang') === 'pt' ? 'pt' : 'en') as Locale;
const t = ui[locale];

const exampleVerse = `{
  "order": 1,
  "lines": [
    {
      "start": 0,
      "original": "श्रीगुरु चरण सरोज रज",
      "transliteration": "śrī guru charaṇa sarōja raja",
      "translations": { "pt": "Com a poeira dos pés de lótus do venerável Guru", "en": "With the dust of the lotus feet of the revered Guru" }
    }
  ]
}`;
---

<BaseLayout
  title={t.contribute.title}
  description={t.contribute.description}
  locale={locale}
>
  <PageShell>
    <h1 class="font-serif text-sc-3xl sc-heading mb-page-heading">
      {t.contribute.title}
    </h1>
    <p class="mb-page-content" style="color: var(--sc-text-muted)">
      {t.contribute.description}
    </p>

    <div class="prose max-w-none" style="color: var(--sc-text-muted)">
      <h2 class="font-serif text-sc-xl sc-heading mt-section-gap mb-4" style="color: var(--sc-text)">How to add a chant</h2>
      <ol class="list-decimal list-inside space-y-3">
        <li>Create a new JSON file in <code class="px-1 rounded" style="background-color: var(--sc-border)">src/content/chants/</code> (e.g. <code class="px-1 rounded" style="background-color: var(--sc-border)">my-chant.json</code>).</li>
        <li>Follow the chant schema (see below). The filename without extension becomes the chant slug/URL.</li>
        <li>Run <code class="px-1 rounded" style="background-color: var(--sc-border)">npm run dev</code> to preview.</li>
        <li>Submit a pull request with your new file.</li>
      </ol>

      <h2 class="font-serif text-sc-xl sc-heading mt-section-gap mb-4" style="color: var(--sc-text)">Chant schema</h2>
      <p class="mb-4">
        Each chant file must include:
      </p>
      <ul class="list-disc list-inside space-y-2">
        <li><strong>slug</strong> — same as filename (e.g. <code>my-chant</code>)</li>
        <li><strong>title</strong> — display name</li>
        <li><strong>tradition</strong> — e.g. Hindu, Buddhist, Indigenous</li>
        <li><strong>language</strong> — original language name</li>
        <li><strong>description</strong> — short description</li>
        <li><strong>verses</strong> — array of verse objects (order, <strong>lines</strong>). Each line has <strong>start</strong> (seconds for sync), original, transliteration, translations.pt/en.</li>
        <li><strong>tags</strong> — optional array of strings</li>
        <li><strong>audio</strong> — optional URL to an audio file</li>
      </ul>

      <h2 class="font-serif text-sc-xl sc-heading mt-section-gap mb-4" style="color: var(--sc-text)">Lyric sync (optional)</h2>
      <p class="mb-2">
        If the chant has <strong>audio</strong>, add a <strong>start</strong> time (seconds) to each <strong>line</strong>. Sync is line-level: the current line is highlighted and the page scrolls (karaoke-style). Use the same order as sung: first line <code class="px-1 rounded" style="background-color: var(--sc-border)">"start": 0</code>, next line the time it starts, etc. To get timestamps, play the track and note when each line starts, or use a helper tool.
      </p>

      <h2 class="font-serif text-sc-xl sc-heading mt-section-gap mb-4" style="color: var(--sc-text)">Example verse</h2>
      <pre class="p-4 rounded-lg text-sm overflow-x-auto" style="background-color: var(--sc-border)"><code>{exampleVerse}</code></pre>

      <p class="mt-section text-sm" style="color: var(--sc-text-subtle)">
        For the full schema, see <code class="px-1 rounded" style="background-color: var(--sc-border)">src/content/schemas/chant.ts</code>.
      </p>
    </div>
  </PageShell>
</BaseLayout>
