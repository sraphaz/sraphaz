---
interface Props {
  src: string;
  title?: string;
  /** Id for lyric-sync script to attach timeupdate listener; always set so the element is identifiable. */
  id?: string;
  /** Compact layout for use inside the fixed player bar (reduces height). */
  compact?: boolean;
}

const { src, title = 'Chant audio', id, compact = false } = Astro.props;
const audioId = id ?? 'chant-audio-player';
const seekId = audioId + '-seek';
const playId = audioId + '-play';
---

{src && (
  <div class:list={['chant-audio-box', 'w-full', compact && 'chant-audio-box--compact']} role="group" aria-label={title}>
    <div class:list={compact ? ['flex', 'items-center', 'gap-2', 'w-full', 'min-w-0'] : ['rounded-lg', 'p-4', 'flex', 'flex-col', 'gap-3']} style={!compact ? 'background-color: var(--sc-bg); border: 1px solid var(--sc-border);' : undefined}>
      <audio
        id={audioId}
        preload="metadata"
        class="hidden"
        aria-hidden="true"
      >
        <source src={src} type="audio/mpeg" />
        <source src={src} type="audio/ogg" />
      </audio>
      <div class:list={['flex', 'items-center', 'gap-2', compact && 'flex-1', 'min-w-0']}>
        <button
          type="button"
          id={playId}
          class:list={['chant-audio-play flex-shrink-0 rounded-full flex items-center justify-center border cursor-pointer transition-colors', compact ? 'w-7 h-7 border text-sm' : 'w-10 h-10 border-2']}
          style="background-color: var(--sc-bg); border-color: var(--sc-border); color: var(--sc-text);"
          aria-label={title + ' — play'}
        >
          <span aria-hidden="true">▶</span>
        </button>
        <label class="flex-1 min-w-0 flex flex-col gap-0" for={seekId}>
          <input
            type="range"
            id={seekId}
            name="chant-audio-seek"
            min="0"
            max="100"
            value="0"
            class:list={['chant-audio-seek w-full rounded-full cursor-pointer accent-current', compact ? 'h-1.5' : 'h-2']}
            style="color: var(--sc-text-muted);"
            aria-label="Position"
          />
        </label>
      </div>
    </div>
    <script is:inline define:vars={{ audioId, seekId, playId }}>
      (function() {
        var audio = document.getElementById(audioId);
        var seek = document.getElementById(seekId);
        var playBtn = document.getElementById(playId);
        if (!audio || !seek || !playBtn) return;
        function setPlaying(playing) {
          playBtn.innerHTML = playing ? '<span aria-hidden="true">⏸</span>' : '<span aria-hidden="true">▶</span>';
          playBtn.setAttribute('aria-label', audio.getAttribute('aria-label') + (playing ? ' — pause' : ' — play'));
        }
        function updateSeek() {
          var pct = audio.duration ? (100 * audio.currentTime / audio.duration) : 0;
          seek.value = String(pct);
        }
        audio.addEventListener('loadedmetadata', updateSeek);
        audio.addEventListener('timeupdate', updateSeek);
        audio.addEventListener('play', function() { setPlaying(true); });
        audio.addEventListener('pause', function() { setPlaying(false); });
        audio.addEventListener('ended', function() { setPlaying(false); updateSeek(); });
        playBtn.addEventListener('click', function() {
          if (audio.paused) audio.play(); else audio.pause();
        });
        seek.addEventListener('input', function() {
          var t = (audio.duration || 0) * (Number(seek.value) / 100);
          audio.currentTime = t;
        });
        setPlaying(false);
      })();
    </script>
  </div>
)}
