---
import '../styles/global.css';
import { ui, type Locale } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, description = 'A living library of sacred sound traditions.' } = Astro.props;
const tEn = ui.en;
const tPt = ui.pt;
/** Initial locale from URL so the correct language shows on first paint (no flash of EN). */
const urlLang = Astro.url.searchParams.get('lang');
const initialLocale: Locale = urlLang === 'pt' ? 'pt' : 'en';
---

<!doctype html>
<html lang={initialLocale} data-locale={initialLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} | Sacred Chants</title>
    <script is:inline>
      (function() {
        var STORAGE = 'sacred-chants-';
        var root = document.documentElement;
        root.dataset.theme = localStorage.getItem(STORAGE + 'theme') || 'dark';
        root.dataset.fontSize = localStorage.getItem(STORAGE + 'fontSize') || 'medium';
        root.dataset.fontFamily = localStorage.getItem(STORAGE + 'fontFamily') || 'sans';
        root.dataset.spacing = localStorage.getItem(STORAGE + 'spacing') || 'normal';
        var verseTint = localStorage.getItem(STORAGE + 'verseTint') || 'default';
        if (verseTint) root.dataset.verseTint = verseTint;
        var textColor = localStorage.getItem(STORAGE + 'textColor') || 'default';
        if (textColor) root.dataset.textColor = textColor;
        var bg = localStorage.getItem(STORAGE + 'bg') || 'default';
        if (bg) root.dataset.bg = bg;
        var savedLang = localStorage.getItem(STORAGE + 'lang');
        var q = new URLSearchParams(window.location.search);
        var urlLang = q.get('lang');
        if (savedLang && !urlLang) {
          q.set('lang', savedLang);
          window.location.replace(window.location.pathname + (q.toString() ? '?' + q.toString() : ''));
          return;
        }
        var locale = urlLang === 'pt' ? 'pt' : (savedLang === 'pt' ? 'pt' : 'en');
        root.dataset.locale = locale;
        root.lang = locale === 'pt' ? 'pt' : 'en';
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sc-header backdrop-blur">
      <nav class="sc-header__nav w-full flex flex-nowrap items-center gap-3 sc-header__nav-pad">
        <div class="sc-header__brand shrink-0">
          <a href="/" class="locale-en font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-en">Sacred Chants</span></a>
          <a href="/?lang=pt" class="locale-pt font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-pt">Sacred Chants</span></a>
        </div>
        <div class="sc-header__menu-wrap flex-1 flex justify-center min-w-0 shrink">
          <ul class="sc-header__menu flex flex-nowrap items-center justify-center gap-3 md:gap-5 text-sm whitespace-nowrap">
          <li><a href="/" class="locale-en">{tEn.nav.home}</a><a href="/?lang=pt" class="locale-pt">{tPt.nav.home}</a></li>
          <li><a href="/chants" class="locale-en">{tEn.nav.chants}</a><a href="/chants?lang=pt" class="locale-pt">{tPt.nav.chants}</a></li>
          <li><a href="/traditions" class="locale-en">{tEn.nav.traditions}</a><a href="/traditions?lang=pt" class="locale-pt">{tPt.nav.traditions}</a></li>
          <li><a href="/knowledge" class="locale-en">{tEn.nav.knowledge}</a><a href="/knowledge?lang=pt" class="locale-pt">{tPt.nav.knowledge}</a></li>
          <li><a href="/contribute" class="locale-en">{tEn.nav.contribute}</a><a href="/contribute?lang=pt" class="locale-pt">{tPt.nav.contribute}</a></li>
          <li><a href="/settings" class="locale-en">{tEn.nav.settings}</a><a href="/settings?lang=pt" class="locale-pt">{tPt.nav.settings}</a></li>
          </ul>
        </div>
        <div class="sc-header__lang shrink-0 ml-auto flex items-center gap-2">
          <span style="color: var(--sc-text-subtle)" aria-hidden="true">|</span>
          <a href={Astro.url.pathname + '?lang=pt'} class="locale-en text-sm sc-header-a">{tEn.lang.pt}</a>
          <a href={Astro.url.pathname + '?lang=en'} class="locale-pt text-sm sc-header-a">{tPt.lang.en}</a>
        </div>
      </nav>
    </header>
    <main class="flex-1 sc-main-with-header">
      <slot />
    </main>
    <footer class="sc-footer border-t py-8 mt-auto">
      <div class="max-w-content mx-auto px-page-x text-center text-sm">
        <p class="locale-en">Sacred Chants — {tEn.home.tagline}</p>
        <p class="locale-pt">Sacred Chants — {tPt.home.tagline}</p>
        <p class="mt-1" style="color: var(--sc-text-subtle)">Open source · No ads · Contemplative</p>
      </div>
    </footer>
  </body>
</html>
